{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug atx-core-tests",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/atx-core-tests.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "cmake: build (ninja)"
    },
    {
      "name": "Debug atx-engine-tests (pick group)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/bin/atx-engine-${input:atxTestGroup}-tests.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "cmake: build (ninja)"
    }
  ],
  "inputs": [
    {
      "id": "atxTestGroup",
      "type": "pickString",
      "description": "Which atx-engine test group exe to debug?",
      "options": [
        "alpha", "risk", "data", "factory", "parallel", "learn",
        "eval", "library", "combine", "fund", "book", "core"
      ],
      "default": "core"
    }
  ]
}
