{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "ninja",
      "displayName": "Ninja + clang-cl (clangd)",
      "description": "Ninja generator with clang-cl; emits compile_commands.json for clangd. Run from a VS Developer shell or via the VSCode CMake Tools extension so the MSVC environment is present.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "vs",
      "displayName": "Visual Studio 2022 (MSBuild)",
      "description": "Multi-config MSBuild generator for the VS IDE / msbuild CLI.",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build-vs",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "ninja", "configurePreset": "ninja" },
    { "name": "vs", "configurePreset": "vs", "configuration": "Debug" }
  ],
  "testPresets": [
    {
      "name": "ninja",
      "configurePreset": "ninja",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "vs",
      "configurePreset": "vs",
      "configuration": "Debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
