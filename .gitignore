# Build directories
build/
build-rel/
build-vs/
out/
cmake-build-*/

# Git worktrees (isolated workspaces)
.worktrees/

# Downloaded market data (DBN/parquet dumps from examples) — root-level only,
# so it never shadows source dirs like atx-engine/{include/atx/engine,src}/data/.
/data/

# clangd / tooling
.cache/
compile_commands.json
CMakeUserPresets.json

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
Testing/
_deps/

# Secrets / local env (API keys, credentials)
.env
.env.*
!.env.example

# IDE
.vs/
.idea/
*.user

# VSCode: ignore everything except the shared project config below.
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

# Compiled
*.o
*.obj
*.a
*.lib
*.so
*.dylib
*.dll
*.exe

# Generated benchmark / TSDB segment artifacts (e.g. atx_panel_bench.atxseg, 100s of MB)
*.atxseg

# Crash dumps
*.stackdump

# Scratch / experiment dirs (notebooks, throwaway scripts) — not versioned
scratch/
